  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-stack-tabs.es.js",
      "require": "./dist/vue-stack-tabs.umd.js"
    },
    "./nuxt": {
      "types": "./src/lib/nuxt/module.d.ts",
      "default": "./src/lib/nuxt/module.ts"
    },
    "./dist/style.css": "./dist/style.css",
    "./dist/vue-stack-tabs.css": "./dist/vue-stack-tabs.css"
  },
  "peerDependencies": {
    "nuxt": "^3.0.0 || ^4.0.0"
  },

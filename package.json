    "@rushstack/eslint-patch": "^1.16.1",
    "@tsconfig/node20": "^20.1.9",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.9.1",
    "@types/throttle-debounce": "^5.0.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/coverage-v8": "4.1.7",

    "@vue/reactivity": "^3.5.35",
    "@vue/runtime-core": "^3.5.35",
    "@vue/runtime-dom": "^3.5.35",
    "@vue/shared": "^3.5.35",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "@vueuse/core": "^14.3.0",
    "@vueuse/shared": "^14.3.0",
    "async-validator": "^4.2.5",
    "birpc": "^4.0.0",
    "dayjs": "^1.11.21",
    "element-plus": "^2.14.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
